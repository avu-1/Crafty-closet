# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── MySQL — use ONE of the following ──────────────────────────
# Option A: Connection URL (Aiven / PlanetScale / Render MySQL)
MYSQL_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# Option B: Individual vars (local dev)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=yourpassword
# DB_NAME=crafty_closet_v2

# ── Firebase Admin SDK ────────────────────────────────────────
# Base64-encoded service account JSON
# Encode: [Convert]::ToBase64String([IO.File]::ReadAllBytes('serviceAccount.json'))
FIREBASE_SERVICE_ACCOUNT=<base64-encoded-json>

# ── CORS ──────────────────────────────────────────────────────
# Your Firebase Hosting URL (comma-separate multiple origins)
CLIENT_URL=https://crafty-closet-5dc41.web.app

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Nodemailer ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@gmail.com
MAIL_PASS=<gmail-app-password>
MAIL_FROM="Crafty Closet <you@gmail.com>"
