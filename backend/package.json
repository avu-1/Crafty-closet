{
  "name": "crafty-closet-backend",
  "version": "2.0.0",
  "description": "Crafty Closet REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "import-schema": "node scripts/import-schema.js",
    "migrate-images": "node scripts/migrate-images-to-firebase.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "firebase-admin": "^13.9.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.9.13",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ],
    "moduleNameMapper": {
      "../config/db": "<rootDir>/tests/__mocks__/db.js",
      "./config/db": "<rootDir>/tests/__mocks__/db.js",
      "../config/firebase": "<rootDir>/tests/__mocks__/firebase-admin.js",
      "./config/firebase": "<rootDir>/tests/__mocks__/firebase-admin.js",
      "firebase-admin": "<rootDir>/tests/__mocks__/firebase-admin.js"
    },
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "routes/**/*.js"
    ],
    "coverageDirectory": "coverage"
  }
}
